HOST=127.0.0.1
PORT=4000

# Comma-separated exact frontend origins that may call backend APIs.
# Example: https://memo.example.com,http://localhost:3000
FRONTEND_ORIGINS=http://localhost:3000

# Set to 1 only if you intentionally trust all *.vercel.app preview URLs.
ALLOW_VERCEL_PREVIEWS=0

# Required for strict media proxy in production.
# Supports exact hosts and wildcard suffixes like *.example.com
MEDIA_PROXY_ALLOWED_HOSTS=animesalt.ac,*.animesalt.ac,krussdomi.com,*.krussdomi.com,animetsu.net,ani.metsu.site,airesearchlab.xyz,*.airesearchlab.xyz,advancedairesearchlab.xyz,*.advancedairesearchlab.xyz,bysekoze.com,*.r66nv9ed.com,rapid-cloud.co,*.rapid-cloud.co,seiryuu.vid-cdn.xyz,*.vid-cdn.xyz,anizone.to

# Optional override. Defaults to 1 in production, 0 outside production.
MEDIA_PROXY_STRICT_MODE=0

SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your_supabase_service_role_key
